erDiagram
    USERS ||--o{ ACCOUNT_META : "owns"
    USERS ||--o{ USER_IDENTIFIERS : "has"
    ACCOUNT_META ||..o{ LEDGER_DDB : "balance is latest entry's balance_after"
    TRANSFERS_META ||--o{ TRANSFER_EVENTS : "tracked by"
    TRANSFERS_META ||..|{ LEDGER_DDB : "money truth in (>=2 entries)"

    USERS {
        uuid user_id PK
        string status "KYC done (upstream)"
        timestamp created_at
        string note "[PostgreSQL — metadata]"
    }

    USER_IDENTIFIERS {
        uuid user_id FK
        string type "EMAIL | PHONE"
        string value UK "resolution key (indexed)"
        string note "[PostgreSQL — metadata]"
    }

    ACCOUNT_META {
        uuid account_id PK
        uuid user_id FK "null for system accounts"
        string type "USER | ESCROW (clearing)"
        bigint balance_cache_minor "DISPLAY CACHE ONLY (not authoritative)"
        string currency "fixed to USD"
        string note "[PostgreSQL — non-money metadata + cache]"
    }

    TRANSFERS_META {
        uuid transfer_id PK
        uuid sender_account FK
        uuid recipient_account FK
        string status "DEBITED|FRAUD_REVIEW|MORATORIUM|SETTLED|CANCELLED|REVERSED"
        string idempotency_key UK "client-issued; blocks double-processing"
        string note_text "user memo, searchable"
        timestamp created_at
        timestamp settle_after "moratorium expiry"
        string note "[PostgreSQL — metadata/search/workflow]"
    }

    TRANSFER_EVENTS {
        uuid event_id PK
        uuid transfer_id FK
        string step "FRAUD|MORATORIUM|SETTLE|NOTIFY"
        string state "PENDING|DONE|FAILED|MANUAL_REVIEW"
        timestamp created_at
        string note "[PostgreSQL — workflow state]"
    }

    LEDGER_DDB {
        string partition_key "ACCOUNT-id"
        bigint seq "sort key; per-account sequence"
        uuid entry_id "unique"
        uuid transfer_id "GSI"
        string idempotency_key "guards double-processing"
        string phase "DEBIT_TO_ESCROW | ESCROW_TO_RECIPIENT | REVERSAL"
        bigint amount_minor "signed (+credit / -debit)"
        bigint balance_after "post-txn balance — THIS IS THE CURRENT BALANCE"
        string note "[DynamoDB — ledger = money truth, append-only, 7y]"
    }
