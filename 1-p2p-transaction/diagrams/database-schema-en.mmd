erDiagram
    USERS ||--o{ ACCOUNT_META : "owns"
    USERS ||--o{ USER_IDENTIFIERS : "has"
    ACCOUNT_META ||..|| BALANCE_DDB : "authoritative balance in"
    BALANCE_DDB ||..o{ LEDGER_DDB : "each settled move appends entries"
    TRANSFERS_META ||--o{ TRANSFER_EVENTS : "tracked by"
    TRANSFERS_META ||..|{ LEDGER_DDB : "settlement writes (>=2 entries)"

    USERS {
        uuid user_id PK
        string status "KYC done (upstream)"
        timestamp created_at
        string note "[PostgreSQL — metadata]"
    }

    USER_IDENTIFIERS {
        uuid user_id FK
        string type "EMAIL | PHONE"
        string value UK "resolution key (indexed)"
        string note "[PostgreSQL — metadata]"
    }

    ACCOUNT_META {
        uuid account_id PK
        uuid user_id FK
        string currency "fixed to USD"
        bigint balance_cache_minor "DISPLAY CACHE ONLY (not authoritative)"
        string note "[PostgreSQL — non-money metadata + cache]"
    }

    TRANSFERS_META {
        uuid transfer_id PK
        uuid sender_account FK
        uuid recipient_account FK
        bigint amount_minor "(also held against sender until settle)"
        string status "DEBITED|FRAUD_REVIEW|MORATORIUM|SETTLED|CANCELLED"
        string idempotency_key UK "client-issued; blocks double-processing"
        string note_text "user memo, searchable"
        timestamp created_at
        timestamp settle_after "moratorium expiry"
        string note "[PostgreSQL — metadata/search/workflow]"
    }

    TRANSFER_EVENTS {
        uuid event_id PK
        uuid transfer_id FK
        string step "FRAUD|MORATORIUM|SETTLE|NOTIFY"
        string state "PENDING|DONE|FAILED|MANUAL_REVIEW"
        timestamp created_at
        string note "[PostgreSQL — workflow state]"
    }

    BALANCE_DDB {
        string partition_key "ACCOUNT-id"
        bigint available_minor "real balance (decremented at SETTLE)"
        bigint held_minor "reserved by in-flight transfers (set at POST)"
        bigint version "OPTIMISTIC LOCK: every write ConditionExpression version = expected, sets version+1"
        timestamp updated_at "last mutation time"
        string note "[DynamoDB — authoritative balance; available - held = spendable]"
    }

    LEDGER_DDB {
        string partition_key "ACCOUNT-id"
        bigint seq "sort key; per-account sequence"
        uuid entry_id "unique"
        uuid transfer_id "GSI"
        string idempotency_key "guards double-processing"
        string type "DEBIT | CREDIT | REVERSAL"
        bigint amount_minor "signed (+credit / -debit)"
        bigint balance_after "available balance AFTER this entry"
        bigint balance_version "version of BALANCE_DDB this entry committed against"
        timestamp created_at "settlement time (append-only)"
        string note "[DynamoDB — append-only at SETTLE only, 7y]"
    }
