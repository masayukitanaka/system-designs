erDiagram
    USERS ||--o{ ACCOUNTS : "owns"
    USERS ||--o{ USER_IDENTIFIERS : "has"
    ACCOUNTS ||--o{ LEDGER_ENTRIES : "records"
    TRANSFERS ||--|{ LEDGER_ENTRIES : "produces (2 entries)"
    TRANSFERS ||--o| IDEMPOTENCY_KEYS : "guarded by"

    USERS {
        uuid user_id PK
        string status "KYC済 (上流)"
        timestamp created_at
    }

    USER_IDENTIFIERS {
        uuid user_id FK
        string type "EMAIL | PHONE"
        string value UK "解決キー (索引)"
    }

    ACCOUNTS {
        uuid account_id PK
        uuid user_id FK
        bigint balance_minor "残高 (セント単位)"
        bigint version "楽観ロック"
        string currency "USD固定"
    }

    TRANSFERS {
        uuid transfer_id PK
        uuid sender_account FK
        uuid recipient_account FK
        bigint amount_minor
        string status "PENDING|COMPLETED|FAILED|REVERSED"
        string idempotency_key UK
        timestamp created_at
    }

    LEDGER_ENTRIES {
        uuid entry_id PK
        uuid transfer_id FK
        uuid account_id FK
        bigint amount_minor "符号付 (+credit / -debit)"
        bigint balance_after "監査用スナップショット"
        timestamp created_at "追記のみ / 不変"
    }

    IDEMPOTENCY_KEYS {
        string key PK
        string request_hash
        string response_snapshot
        string state "PROCESSING|SUCCESS|FAILED"
        timestamp expires_at "TTL 24h"
    }
