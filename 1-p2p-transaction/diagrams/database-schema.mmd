erDiagram
    USERS ||--o{ ACCOUNT_META : "owns"
    USERS ||--o{ USER_IDENTIFIERS : "has"
    ACCOUNT_META ||..|| BALANCE_DDB : "正の残高はここ"
    BALANCE_DDB ||..o{ LEDGER_DDB : "決済ごとにエントリ追記"
    TRANSFERS_META ||--o{ TRANSFER_EVENTS : "tracked by"
    TRANSFERS_META ||..|{ LEDGER_DDB : "決済時に書く (>=2 entries)"

    USERS {
        uuid user_id PK
        string status "KYC done (upstream)"
        timestamp created_at
        string note "[PostgreSQL — メタデータ]"
    }

    USER_IDENTIFIERS {
        uuid user_id FK
        string type "EMAIL | PHONE"
        string value UK "解決キー (索引)"
        string note "[PostgreSQL — メタデータ]"
    }

    ACCOUNT_META {
        uuid account_id PK
        uuid user_id FK
        string currency "USD固定"
        bigint balance_cache_minor "表示用キャッシュのみ (正ではない)"
        string note "[PostgreSQL — 非金額メタ + キャッシュ]"
    }

    TRANSFERS_META {
        uuid transfer_id PK
        uuid sender_account FK
        uuid recipient_account FK
        bigint amount_minor "(決済まで送金者にheldされる額)"
        string status "DEBITED|FRAUD_REVIEW|MORATORIUM|SETTLED|CANCELLED"
        string idempotency_key UK "クライアント発行; 二重処理を防止"
        string note_text "ユーザーメモ, 検索可"
        timestamp created_at
        timestamp settle_after "モラトリアム満了"
        string note "[PostgreSQL — メタ/検索/ワークフロー]"
    }

    TRANSFER_EVENTS {
        uuid event_id PK
        uuid transfer_id FK
        string step "FRAUD|MORATORIUM|SETTLE|NOTIFY"
        string state "PENDING|DONE|FAILED|MANUAL_REVIEW"
        timestamp created_at
        string note "[PostgreSQL — ワークフロー状態]"
    }

    BALANCE_DDB {
        string partition_key "ACCOUNT-id"
        bigint available_minor "実残高 (SETTLE時に減算)"
        bigint held_minor "処理中送金の保留額 (POST時に設定)"
        bigint version "楽観ロック: 全書込で ConditionExpression version = expected, version+1 に更新"
        timestamp updated_at "最終更新時刻"
        string note "[DynamoDB — 正の残高; available - held = 利用可能]"
    }

    LEDGER_DDB {
        string partition_key "ACCOUNT-id"
        bigint seq "ソートキー; 勘定ごとの連番"
        uuid entry_id "ユニーク"
        uuid transfer_id "GSI"
        string idempotency_key "二重処理ガード"
        string type "DEBIT | CREDIT | REVERSAL"
        bigint amount_minor "符号付 (+credit / -debit)"
        bigint balance_after "このエントリ適用後の利用可能残高"
        bigint balance_version "このエントリがコミットした BALANCE_DDB の version"
        timestamp created_at "決済時刻 (追記専用)"
        string note "[DynamoDB — SETTLE時のみ追記, 7年]"
    }
