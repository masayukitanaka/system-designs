erDiagram
    USERS ||--o{ ACCOUNT_META : "owns"
    USERS ||--o{ USER_IDENTIFIERS : "has"
    ACCOUNT_META ||..o{ LEDGER_DDB : "残高は最新エントリのbalance_after"
    TRANSFERS_META ||--o{ TRANSFER_EVENTS : "tracked by"
    TRANSFERS_META ||..|{ LEDGER_DDB : "金額の真実 (>=2 entries)"

    USERS {
        uuid user_id PK
        string status "KYC done (upstream)"
        timestamp created_at
        string note "[PostgreSQL — メタデータ]"
    }

    USER_IDENTIFIERS {
        uuid user_id FK
        string type "EMAIL | PHONE"
        string value UK "解決キー (索引)"
        string note "[PostgreSQL — メタデータ]"
    }

    ACCOUNT_META {
        uuid account_id PK
        uuid user_id FK "システム勘定はnull"
        string type "USER | ESCROW (clearing)"
        bigint balance_cache_minor "表示用キャッシュのみ (正ではない)"
        string currency "USD固定"
        string note "[PostgreSQL — 非金額メタ + キャッシュ]"
    }

    TRANSFERS_META {
        uuid transfer_id PK
        uuid sender_account FK
        uuid recipient_account FK
        string status "DEBITED|FRAUD_REVIEW|MORATORIUM|SETTLED|CANCELLED|REVERSED"
        string idempotency_key UK "クライアント発行; 二重処理を防止"
        string note_text "ユーザーメモ, 検索可"
        timestamp created_at
        timestamp settle_after "モラトリアム満了"
        string note "[PostgreSQL — メタ/検索/ワークフロー]"
    }

    TRANSFER_EVENTS {
        uuid event_id PK
        uuid transfer_id FK
        string step "FRAUD|MORATORIUM|SETTLE|NOTIFY"
        string state "PENDING|DONE|FAILED|MANUAL_REVIEW"
        timestamp created_at
        string note "[PostgreSQL — ワークフロー状態]"
    }

    LEDGER_DDB {
        string partition_key "ACCOUNT-id"
        bigint seq "ソートキー; 勘定ごとの連番"
        uuid entry_id "ユニーク"
        uuid transfer_id "GSI"
        string idempotency_key "二重処理ガード"
        string phase "DEBIT_TO_ESCROW | ESCROW_TO_RECIPIENT | REVERSAL"
        bigint amount_minor "符号付 (+credit / -debit)"
        bigint balance_after "処理後残高 — これが現在残高"
        string note "[DynamoDB — 台帳=金額の真実, 追記専用, 7年]"
    }
