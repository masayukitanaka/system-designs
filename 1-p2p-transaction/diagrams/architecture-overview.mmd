graph TB
    subgraph Client["クライアント層"]
        MOBILE["モバイルアプリ / Web"]
    end

    subgraph Edge["エッジ層"]
        CDN["CloudFront (CDN)"]
        WAF["AWS WAF"]
        APIGW["API Gateway / ALB"]
    end

    subgraph Upstream["上流サービス (スコープ外)"]
        AUTH["認証サービス<br/>(JWT発行 / KYC済)"]
    end

    subgraph Core["コアサービス (本設計のスコープ)"]
        TRANSFER["<b>Transfer Service</b><br/>同期受付: Ledgerをコールしてhold,<br/>TransferRequested発火, 受付完了+残高を返却<br/>(薄いオーケストレーション, 金額データを持たない)"]
        LEDGER["<b>Ledger Service</b><br/>金額+メタ+ワークフローの唯一の所有者<br/>残高(available/held)+台帳(DynamoDB)<br/>+ transfersメタ/冪等性/status(PostgreSQL)<br/><b>TransferRequested を消費 → Temporalワークフロー実行</b><br/>fraud Activity → モラトリアム(durable timer) → 決済(内部) → 通知"]
        USER["User Directory Service<br/>電話/Email → userId 解決"]
        NOTIFY["Notification Service<br/>Push / SMS / Email"]
        FRAUD["Fraud Rule Engine<br/>fraud / AML チェック (+ 人手承認)"]
    end

    subgraph Orch["ワークフロー オーケストレーション"]
        TSERVER["Temporal Service<br/>(状態・タイマー・リトライを永続管理)"]
    end

    subgraph Async["非同期基盤"]
        MQ["Kafka / SQS<br/>イベントバス (TransferRequested, 通知)"]
    end

    subgraph Data["データ層"]
        DDB[("<b>DynamoDB — 正 (金額)</b><br/>残高アイテム (available / held) + 台帳 (約126億行/年, 7年)<br/>POST: hold(予約); SETTLE: 送金 + 台帳追記<br/>条件付き書込 + 冪等ガード")]
        LEDGERDB[("PostgreSQL (Aurora)<br/>メタデータ: users / transfersメタ / events / idempotency<br/>+ 残高<i>表示キャッシュ</i> (正ではない)")]
        CACHE[("Redis<br/>キャッシュ / レート制限")]
        ARCHIVE[("S3 Object Lock (WORM) + Glacier<br/>追記専用 監査ログ, 7年 / DynamoDBエクスポート")]
    end

    subgraph External["外部連携"]
        ML["ML 不正スコアリング API"]
        AML["AML スクリーニング API"]
        BANK["銀行/決済ネットワーク<br/>(RTP / FedNow)"]
    end

    MOBILE --> CDN --> WAF --> APIGW
    APIGW -->|JWT検証| AUTH
    APIGW -->|同期: 送金作成| TRANSFER

    TRANSFER --> USER
    TRANSFER --> CACHE
    TRANSFER -->|同期: hold + 受付| LEDGER
    TRANSFER -->|TransferRequested 発火| MQ

    LEDGER -->|hold + 決済 残高 + 台帳<br/>条件付き UpdateItem / TransactWriteItems| DDB
    LEDGER -.残高 / 履歴 読取.-> DDB
    LEDGER -->|transfersメタ / 冪等性 / status| LEDGERDB

    MQ -->|TransferRequested| LEDGER
    LEDGER <-->|ワークフロー起動 / signal / タスクpoll| TSERVER
    LEDGER -->|fraud / AML Activity| FRAUD
    LEDGER --> BANK
    LEDGER -->|両者へ通知| MQ
    MQ --> NOTIFY

    FRAUD -->|高リスク時| ML
    FRAUD --> AML

    DDB -->|DynamoDB Streams<br/>残高キャッシュ更新| LEDGERDB
    DDB -.エクスポート.-> ARCHIVE

    classDef scope fill:#e3f2fd,stroke:#1565c0,stroke-width:2px;
    classDef ext fill:#fff3e0,stroke:#e65100,stroke-width:1px;
    classDef data fill:#f1f8e9,stroke:#33691e,stroke-width:1px;
    classDef orch fill:#ede7f6,stroke:#4527a0,stroke-width:2px;
    class TRANSFER,LEDGER,USER,NOTIFY,FRAUD scope;
    class ML,AML,BANK,AUTH ext;
    class DDB,LEDGERDB,CACHE,ARCHIVE data;
    class TSERVER orch;
