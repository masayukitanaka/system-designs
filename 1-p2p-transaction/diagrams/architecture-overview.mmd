graph TB
    subgraph Client["クライアント層"]
        MOBILE["モバイルアプリ / Web"]
    end

    subgraph Edge["エッジ層"]
        CDN["CloudFront (CDN)"]
        WAF["AWS WAF"]
        APIGW["API Gateway / ALB"]
    end

    subgraph Upstream["上流サービス (スコープ外)"]
        AUTH["認証サービス<br/>(JWT発行 / KYC済)"]
    end

    subgraph Core["コアサービス (本設計のスコープ)"]
        PAYMENTS["<b>Payments Service</b><br/>同期: 送金者→escrowへ減算 (DynamoDB Tx), 200返却, イベント発火<br/>+ 冪等性 + 二重仕訳台帳<br/>+ 残高/履歴の読取 (DynamoDBから)<br/><i>(金額の真実はDynamoDB)</i>"]
        WF["Settlement Workflow<br/>ステートマシン: fraud → モラトリアム<br/>→ 振込確定 → 通知<br/><i>(複雑なら Step Functions)</i>"]
        USER["User Directory Service<br/>電話/Email → userId 解決"]
        NOTIFY["Notification Service<br/>Push / SMS / Email"]
        FRAUD["Fraud Rule Engine<br/>fraud / AML チェック (+ 人手承認)"]
    end

    subgraph Async["非同期基盤"]
        MQ["Kafka / SQS<br/>イベントバス"]
    end

    subgraph Data["データ層"]
        DDB[("<b>DynamoDB — 正 (金額)</b><br/>全台帳 (約126億行/年), 追記専用, 7年, account_id別<br/>残高 = 最新エントリのbalance_after<br/>TransactWriteItems + 冪等ガードで原子的")]
        LEDGERDB[("PostgreSQL (Aurora)<br/>メタデータ: users / transfersメタ / events / idempotency<br/>+ 残高<i>表示キャッシュ</i> (正ではない)")]
        CACHE[("Redis<br/>キャッシュ / レート制限")]
        ARCHIVE[("S3 + Glacier<br/>監査長期保管 / DynamoDBエクスポート")]
    end

    subgraph External["外部連携"]
        ML["ML 不正スコアリング API"]
        AML["AML スクリーニング API"]
        BANK["銀行/決済ネットワーク<br/>(RTP / FedNow)"]
    end

    MOBILE --> CDN --> WAF --> APIGW
    APIGW -->|JWT検証| AUTH
    APIGW -->|同期: 作成 + 減算| PAYMENTS

    PAYMENTS --> USER
    PAYMENTS --> CACHE
    PAYMENTS -->|残高 + 台帳<br/>原子的 TransactWriteItems| DDB
    PAYMENTS -.残高 / 履歴 読取.-> DDB
    PAYMENTS -->|メタデータ / transfers / events| LEDGERDB
    PAYMENTS -->|イベント発火| MQ

    MQ -->|ワークフロー駆動| WF
    WF --> FRAUD
    WF -->|モラトリアム後に振込確定| PAYMENTS
    WF --> BANK
    WF -->|両者へ通知| NOTIFY

    FRAUD -->|高リスク時| ML
    FRAUD --> AML

    DDB -->|DynamoDB Streams<br/>残高キャッシュ更新| LEDGERDB
    DDB -.エクスポート.-> ARCHIVE

    classDef scope fill:#e3f2fd,stroke:#1565c0,stroke-width:2px;
    classDef ext fill:#fff3e0,stroke:#e65100,stroke-width:1px;
    classDef data fill:#f1f8e9,stroke:#33691e,stroke-width:1px;
    class PAYMENTS,WF,USER,NOTIFY,FRAUD scope;
    class ML,AML,BANK,AUTH ext;
    class DDB,LEDGERDB,CACHE,ARCHIVE data;
