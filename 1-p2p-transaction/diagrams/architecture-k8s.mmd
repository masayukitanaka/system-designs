graph TB
    subgraph Internet["インターネット"]
        U["クライアント"]
    end

    subgraph AWS["AWS リージョン (Multi-AZ)"]
        R53["Route 53"]
        WAFCF["CloudFront + WAF"]

        subgraph EKS["Amazon EKS クラスタ"]
            ING["Ingress Controller<br/>(ALB Ingress / NGINX)"]

            subgraph NSCore["Namespace: core"]
                direction LR
                TPOD["payments-svc<br/>Deployment x N<br/>(HPA: CPU/TPS)<br/>送金+台帳+履歴"]
                FPOD["fraud-svc<br/>Deployment x N"]
                UPOD["user-svc<br/>Deployment x N"]
                NPOD["notify-svc<br/>Deployment x N"]
            end

            subgraph NSMesh["サービスメッシュ / 共通"]
                MESH["Istio / App Mesh<br/>mTLS, リトライ, サーキットブレーカ"]
                ESO["External Secrets Operator<br/>→ AWS Secrets Manager"]
            end

            subgraph NSObs["Namespace: observability"]
                PROM["Prometheus"]
                OTEL["OTel Collector"]
                FLUENT["Fluent Bit"]
            end
        end

        subgraph Managed["マネージドデータサービス (クラスタ外)"]
            DDB[("DynamoDB<br/>残高 + 全台帳<br/>(金額の真実)")]
            AURORA[("Aurora PostgreSQL<br/>メタデータ + 残高キャッシュ")]
            REDIS[("ElastiCache Redis<br/>(クラスタモード)")]
            MSK["MSK (Kafka)"]
            S3B["S3 / Glacier"]
        end
    end

    U --> R53 --> WAFCF --> ING
    ING --> TPOD & FPOD & UPOD
    TPOD -.mTLS.- MESH
    TPOD -->|残高 + 台帳| DDB
    TPOD -->|メタデータ| AURORA
    TPOD --> REDIS
    TPOD --> FPOD & UPOD
    TPOD --> MSK
    MSK --> NPOD
    TPOD -.残高 / 履歴 読取.-> DDB
    DDB -->|Streams: キャッシュ更新| AURORA
    ESO -.シークレット注入.-> TPOD & FPOD & UPOD
    TPOD & FPOD & UPOD & NPOD --> OTEL
    OTEL --> PROM
    TPOD & FPOD & UPOD --> FLUENT
    DDB -.エクスポート.-> S3B

    classDef pod fill:#e3f2fd,stroke:#1565c0,stroke-width:1px;
    classDef infra fill:#ede7f6,stroke:#4527a0,stroke-width:1px;
    classDef data fill:#f1f8e9,stroke:#33691e,stroke-width:1px;
    class TPOD,FPOD,UPOD,NPOD pod;
    class MESH,ESO,PROM,OTEL,FLUENT,ING infra;
    class AURORA,REDIS,MSK,S3B data;
