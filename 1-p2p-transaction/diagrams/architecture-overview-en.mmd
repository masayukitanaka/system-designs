graph TB
    subgraph Client["Client Layer"]
        MOBILE["Mobile App / Web"]
    end

    subgraph Edge["Edge Layer"]
        CDN["CloudFront (CDN)"]
        WAF["AWS WAF"]
        APIGW["API Gateway / ALB"]
    end

    subgraph Upstream["Upstream Services (out of scope)"]
        AUTH["Auth Service<br/>(JWT issuance / KYC done)"]
    end

    subgraph Core["Core Services (scope of this design)"]
        TRANSFER["<b>Transfer Service</b><br/>SYNC receive: calls Ledger to hold,<br/>fires TransferRequested, returns accepted + balance<br/>(thin orchestration, owns no money data)"]
        LEDGER["<b>Ledger Service</b><br/>SOLE owner of money + metadata + workflow<br/>balance (available/held) + ledger (DynamoDB)<br/>+ transfers meta / idempotency / status (PostgreSQL)<br/><b>Consumes TransferRequested → runs Temporal workflow</b><br/>fraud Activity → moratorium (durable timer) → settle (local) → notify"]
        USER["User Directory Service<br/>phone/email → userId resolution"]
        NOTIFY["Notification Service<br/>Push / SMS / Email"]
        FRAUD["Fraud Rule Engine<br/>fraud / AML checks (+ manual review)"]
    end

    subgraph Orch["Workflow Orchestration"]
        TSERVER["Temporal Service<br/>(durable state, timers, retries)"]
    end

    subgraph Async["Async Infrastructure"]
        MQ["Kafka / SQS<br/>event bus (TransferRequested, notifications)"]
    end

    subgraph Data["Data Layer"]
        DDB[("<b>DynamoDB — source of truth (money)</b><br/>balance items (available / held) + ledger (~12.6B rows/yr, 7-year)<br/>POST: hold (reserve); SETTLE: move money + append ledger<br/>conditional writes + idempotency guard")]
        LEDGERDB[("PostgreSQL (Aurora)<br/>metadata: users / transfers meta / events / idempotency<br/>+ balance <i>display cache</i> (NOT authoritative)")]
        CACHE[("Redis<br/>cache / rate limit")]
        ARCHIVE[("S3 Object Lock (WORM) + Glacier<br/>append-only audit log, 7-year / DynamoDB export")]
    end

    subgraph External["External Integrations"]
        ML["ML Fraud Scoring API"]
        AML["AML Screening API"]
        BANK["Bank/Payment Network<br/>(RTP / FedNow)"]
    end

    MOBILE --> CDN --> WAF --> APIGW
    APIGW -->|JWT verify| AUTH
    APIGW -->|sync: create transfer| TRANSFER

    TRANSFER --> USER
    TRANSFER --> CACHE
    TRANSFER -->|sync: hold + accept| LEDGER
    TRANSFER -->|fire TransferRequested| MQ

    LEDGER -->|hold + settle balance + ledger<br/>conditional UpdateItem / TransactWriteItems| DDB
    LEDGER -.balance / history read.-> DDB
    LEDGER -->|transfers meta / idempotency / status| LEDGERDB

    MQ -->|TransferRequested| LEDGER
    LEDGER <-->|start workflow / signals / poll tasks| TSERVER
    LEDGER -->|fraud / AML Activity| FRAUD
    LEDGER --> BANK
    LEDGER -->|notify both parties| MQ
    MQ --> NOTIFY

    FRAUD -->|high risk| ML
    FRAUD --> AML

    DDB -->|DynamoDB Streams<br/>refresh balance cache| LEDGERDB
    DDB -.export.-> ARCHIVE

    classDef scope fill:#e3f2fd,stroke:#1565c0,stroke-width:2px;
    classDef ext fill:#fff3e0,stroke:#e65100,stroke-width:1px;
    classDef data fill:#f1f8e9,stroke:#33691e,stroke-width:1px;
    classDef orch fill:#ede7f6,stroke:#4527a0,stroke-width:2px;
    class TRANSFER,LEDGER,USER,NOTIFY,FRAUD scope;
    class ML,AML,BANK,AUTH ext;
    class DDB,LEDGERDB,CACHE,ARCHIVE data;
    class TSERVER orch;
