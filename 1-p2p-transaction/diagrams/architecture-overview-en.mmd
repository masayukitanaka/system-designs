graph TB
    subgraph Client["Client Layer"]
        MOBILE["Mobile App / Web"]
    end

    subgraph Edge["Edge Layer"]
        CDN["CloudFront (CDN)"]
        WAF["AWS WAF"]
        APIGW["API Gateway / ALB"]
    end

    subgraph Upstream["Upstream Services (out of scope)"]
        AUTH["Auth Service<br/>(JWT issuance / KYC done)"]
    end

    subgraph Core["Core Services (scope of this design)"]
        PAYMENTS["<b>Payments Service</b><br/>SYNC: debit sender → escrow (DynamoDB Tx), return 200, fire event<br/>+ idempotency + double-entry ledger<br/>+ balance/history reads (from DynamoDB)<br/><i>(money truth in DynamoDB)</i>"]
        WF["Settlement Workflow<br/>state machine: fraud → moratorium<br/>→ settle → notify<br/><i>(Step Functions if complex)</i>"]
        USER["User Directory Service<br/>phone/email → userId resolution"]
        NOTIFY["Notification Service<br/>Push / SMS / Email"]
        FRAUD["Fraud Rule Engine<br/>fraud / AML checks (+ manual review)"]
    end

    subgraph Async["Async Infrastructure"]
        MQ["Kafka / SQS<br/>event bus"]
    end

    subgraph Data["Data Layer"]
        DDB[("<b>DynamoDB — source of truth (money)</b><br/>full ledger (~12.6B rows/yr), append-only, 7-year, by account_id<br/>balance = latest entry's balance_after<br/>atomic via TransactWriteItems + idempotency guard")]
        LEDGERDB[("PostgreSQL (Aurora)<br/>metadata: users / transfers meta / events / idempotency<br/>+ balance <i>display cache</i> (NOT authoritative)")]
        CACHE[("Redis<br/>cache / rate limit")]
        ARCHIVE[("S3 + Glacier<br/>long-term audit / DynamoDB export")]
    end

    subgraph External["External Integrations"]
        ML["ML Fraud Scoring API"]
        AML["AML Screening API"]
        BANK["Bank/Payment Network<br/>(RTP / FedNow)"]
    end

    MOBILE --> CDN --> WAF --> APIGW
    APIGW -->|JWT verify| AUTH
    APIGW -->|sync: create + debit| PAYMENTS

    PAYMENTS --> USER
    PAYMENTS --> CACHE
    PAYMENTS -->|balance + ledger<br/>atomic TransactWriteItems| DDB
    PAYMENTS -.balance / history read.-> DDB
    PAYMENTS -->|metadata / transfers / events| LEDGERDB
    PAYMENTS -->|fire event| MQ

    MQ -->|drive workflow| WF
    WF --> FRAUD
    WF -->|moratorium then settle| PAYMENTS
    WF --> BANK
    WF -->|notify both parties| NOTIFY

    FRAUD -->|high risk| ML
    FRAUD --> AML

    DDB -->|DynamoDB Streams<br/>refresh balance cache| LEDGERDB
    DDB -.export.-> ARCHIVE

    classDef scope fill:#e3f2fd,stroke:#1565c0,stroke-width:2px;
    classDef ext fill:#fff3e0,stroke:#e65100,stroke-width:1px;
    classDef data fill:#f1f8e9,stroke:#33691e,stroke-width:1px;
    class PAYMENTS,WF,USER,NOTIFY,FRAUD scope;
    class ML,AML,BANK,AUTH ext;
    class DDB,LEDGERDB,CACHE,ARCHIVE data;
